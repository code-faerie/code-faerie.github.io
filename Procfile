tailwind-watch: npx @tailwindcss/cli -i ./src/css/style.css -o ./src/site/assets/style.css --watch
tailwind-build: npx @tailwindcss/cli -i ./src/css/style.css -o ./src/site/assets/style.css
typescript-watch: npx tsc --watch
typescript-build: npx tsc
jekyll-watch: bundle exec jekyll serve --host 0.0.0.0 --watch
jekyll-build: bundle exec jekyll build
jekyll-serve: bundle exec jekyll serve --host 0.0.0.0
