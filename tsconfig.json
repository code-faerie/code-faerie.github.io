{
    "compilerOptions": {
      "module": "commonjs",
      "esModuleInterop": true,
      "target": "es6",
      "moduleResolution": "node",
      "rootDir": "src/ts",
      "sourceRoot": "src/ts",
      "sourceMap": true,
      "outDir": "src/site/assets",
      "forceConsistentCasingInFileNames": true,
      "strict": true
    },
    "lib": ["es2015"]
}
